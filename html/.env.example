# 삼마디자인 환경 설정
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요

# 사이트 설정
SITE_URL=https://yourdomain.co.kr
ADMIN_EMAIL=admin@yourdomain.co.kr

# DB 설정
DB_HOST=localhost
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# Pixabay API (AI 카드뉴스 배경 이미지용 — 무료)
# 발급: https://pixabay.com/api/docs/ 회원가입 후 무료 발급
PIXABAY_KEY=your_pixabay_key

# FTP 설정 (참고용)
FTP_HOST=yourdomain.dothome.co.kr
FTP_USER=your_ftp_user
